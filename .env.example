# Required: the public origin where Kiln is served.
KILN_URL=http://localhost:3000

# Optional: defaults to prod. Set to dev only on a trusted local installation
# to expose the non-persistent development login bypass.
KILN_ENVIRONMENT=prod

# Required by Relay. Generate with: openssl rand -base64 48
KILN_RELAY_KEY=replace-with-a-long-random-key
KILN_RELAY_PORT=4100

# Optional: create a verified platform administrator automatically on first boot.
KILN_SUPER_USER_EMAIL=
KILN_SUPER_USER_PASSWORD=

# Optional: public registration is off by default. Invitations still work.
KILN_ENABLE_SIGNUPS=false

# Optional: both values are needed to deliver email through Resend. Without
# them, authentication codes and invitation links are written to container logs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Optional: extra origins, comma-separated. KILN_URL is always trusted.
BETTER_AUTH_TRUSTED_ORIGINS=
