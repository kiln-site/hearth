{
  "name": "relay",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--import ./instrument.mjs' tsx watch src/index.ts",
    "format": "vp fmt \"src/**/*.ts\"",
    "lint": "vp lint src",
    "start": "node --import ./dist/instrument.mjs dist/src/index.mjs",
    "test": "vp test run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/core": "2.9.0",
    "@sentry/node": "^10.66.0",
    "@workspace/contracts": "workspace:*",
    "effect": "4.0.0-beta.99",
    "yaml": "2.8.1"
  },
  "devDependencies": {
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "^22",
    "tsx": "^4.20.6",
    "typescript": "^6",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vite-plus": "catalog:"
  }
}
