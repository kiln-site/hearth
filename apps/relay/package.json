{
  "name": "relay",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint src",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workspace/contracts": "workspace:*"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "0.4.0",
    "@types/node": "^22",
    "eslint": "^9",
    "tsx": "^4.20.6",
    "typescript": "^6"
  }
}
