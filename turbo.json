{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "VITE_SENTRY_DSN",
        "VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE",
        "VITE_SENTRY_TRACES_SAMPLE_RATE"
      ],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", "dist/**"],
      "passThroughEnv": [
        "GITHUB_SHA",
        "KILN_BUILD_SHA",
        "SENTRY_AUTH_TOKEN",
        "SOURCE_COMMIT"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
