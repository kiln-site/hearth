# Relay

# REQUIRED in production: shared authentication key used by Hearth. Generate
# with `openssl rand -base64 48`, then set the same value on Hearth when using
# KILN_RELAY_URL or paste it into Hearth's Relay settings UI.
KILN_RELAY_KEY=replace-with-a-long-random-key

# OPTIONAL: Relay API listen port; defaults to 4100.
KILN_RELAY_PORT=4100

# OPTIONAL: persistent Relay state and managed-instance data; defaults to /data.
KILN_RELAY_DATA_DIR=/data

# OPTIONAL: stable identity shown for this Relay node.
RELAY_NODE_ID=kiln-relay-01
RELAY_NODE_NAME=Primary Minecraft node

# OPTIONAL: API listen address; defaults to 0.0.0.0.
RELAY_HOST=0.0.0.0

# OPTIONAL: Docker socket path; defaults to /var/run/docker.sock. The socket must
# also be mounted into the Relay container.
DOCKER_SOCKET=/var/run/docker.sock

# Advanced Relay storage and networking

# OPTIONAL: managed instance root; defaults to KILN_RELAY_DATA_DIR/instances.
RELAY_ROOT=

# OPTIONAL: generated Compose file; defaults to RELAY_ROOT/compose.yaml.
RELAY_COMPOSE_FILE=

# OPTIONAL: Minecraft connection port; defaults to 25565.
RELAY_CONNECT_PORT=25565

# OPTIONAL: internal connection/DNS domain; defaults to test.
RELAY_CONNECT_DOMAIN=test

# OPTIONAL: Docker label used to discover managed containers; defaults to
# kiln.relay.managed=true.
RELAY_MANAGED_LABEL=kiln.relay.managed=true

# OPTIONAL: Docker Compose project directory and project name. They default to
# RELAY_ROOT and mc-servers respectively.
RELAY_PROJECT_DIRECTORY=
RELAY_PROJECT_NAME=mc-servers

# OPTIONAL: label containing each managed server ID; defaults to kiln.server.id.
RELAY_SERVER_ID_LABEL=kiln.server.id

# OPTIONAL: host-visible path matching KILN_RELAY_DATA_DIR. Set this only when
# Relay cannot discover the source of its /data mount through the Docker API.
KILN_RELAY_HOST_DATA_DIR=
