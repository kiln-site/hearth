# Relay

# REQUIRED: Authentication key matching the Relay configured in Hearth
# Generate with: openssl rand -base64 48
KILN_RELAY_KEY=

# OPTIONAL: Relay API listen port
# DEFAULT: 4100
KILN_RELAY_PORT=4100

# Sentry

# OPTIONAL: Enables Sentry for Relay errors and traces. When empty, Sentry is
# disabled.
SENTRY_DSN=

# OPTIONAL: Fraction of Relay transactions captured (0–1).
# DEFAULT: 0.1 in production, 1 in development
SENTRY_TRACES_SAMPLE_RATE=0.1

# Relay stores persistent data in /data.
# Mount /var/run/docker.sock and a persistent volume at /data.
# Health checks can use GET /health without authentication.
