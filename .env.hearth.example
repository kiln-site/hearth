# Database

# REQUIRED: MySQL hostname reachable from the Hearth container.
DB_HOST=mysql

# OPTIONAL: MySQL TCP port; defaults to 3306.
DB_PORT=3306

# REQUIRED: existing MySQL database used by Hearth.
DB_NAME=hearth

# REQUIRED: MySQL account with schema and data access to DB_NAME.
DB_USERNAME=kiln

# REQUIRED: password for DB_USERNAME.
DB_PASSWORD=replace-with-a-strong-database-password

# OPTIONAL: physical prefix for every Hearth and Better Auth table. It must be
# lowercase, end in an underscore, and contain only letters, numbers, and
# underscores. When blank, Kiln derives a stable random-looking prefix such as
# kiln432m_ from BETTER_AUTH_SECRET. Changing the prefix selects a different
# table set; changing BETTER_AUTH_SECRET also changes an auto-derived prefix.
DB_TABLE_PREFIX=

# Hearth panel

# REQUIRED: canonical public origin. Use the browser-facing HTTPS origin when
# Cloudflare, Traefik, Caddy, or nginx terminates TLS in front of Hearth.
KILN_URL=https://hearth.example.com

# REQUIRED (standalone production unless /data is persistent): stable,
# high-entropy secret used for sessions, encrypted Relay credentials, and the
# generated table prefix. Generate with: openssl rand -base64 48
BETTER_AUTH_SECRET=

# OPTIONAL: directory used to persist an automatically generated auth secret;
# defaults to /data. Mount it persistently if BETTER_AUTH_SECRET is omitted.
KILN_DATA_DIR=/data

# OPTIONAL: defaults to prod. Use dev only on a trusted local installation to
# expose the non-persistent development login bypass.
KILN_ENVIRONMENT=prod

# OPTIONAL: defaults to false. Invitations work while public signup is off.
KILN_ENABLE_SIGNUPS=false

# OPTIONAL PAIR: when both are set, first boot creates a verified administrator.
# Leave both blank to use the browser-based first-user flow.
KILN_SUPER_USER_EMAIL=
KILN_SUPER_USER_PASSWORD=

# OPTIONAL: extra browser origins, comma-separated. KILN_URL is always trusted,
# so a normal single-origin reverse-proxy deployment can leave this blank.
BETTER_AUTH_TRUSTED_ORIGINS=

# OPTIONAL PAIR: when both are set, Kiln sends authentication and invitation
# email through Resend. Otherwise, codes and links are written to container logs.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# OPTIONAL: mclo.gs upload API override; defaults to https://api.mclo.gs/1/log.
MCLOGS_API_URL=

# OPTIONAL (build time): source revision displayed in the panel footer. Common
# CI variables such as GITHUB_SHA and COMMIT_SHA are also detected automatically.
KILN_BUILD_SHA=

# Initial Relay bootstrap

# OPTIONAL: when the prefixed Relay table is empty, register this origin as the
# primary Relay. Remote nodes and HTTPS are supported. Do not include credentials,
# a path, query, or fragment. Later env changes do not overwrite database settings.
KILN_RELAY_URL=

# OPTIONAL: name used only when KILN_RELAY_URL seeds an empty Relay table.
KILN_RELAY_NAME=Primary Relay

# REQUIRED only when KILN_RELAY_URL is set: must match KILN_RELAY_KEY on that
# Relay and contain at least 32 characters. Generate with: openssl rand -base64 48
KILN_RELAY_KEY=

# BETTER_AUTH_URL is unnecessary because Kiln passes KILN_URL explicitly.
# DATABASE_URL remains a compatibility fallback but the split DB_* values above
# are canonical. RELAY_URL is obsolete; use KILN_RELAY_URL.
