# Database

# REQUIRED: MySQL hostname
DB_HOST=mysql

# OPTIONAL: MySQL TCP port;
# DEFAULT: 3306.
DB_PORT=

# REQUIRED: MySQL database name
DB_NAME=hearth

# REQUIRED: MySQL username with data access to DB_NAME.
DB_USERNAME=kiln

# REQUIRED: MySQL password for DB_USERNAME.
DB_PASSWORD=replace-with-a-strong-database-password

# OPTIONAL: table prefix for Hearth and Better Auth tables.
# DEFAULT: kiln_
DB_TABLE_PREFIX=kiln_

# Cache

# OPTIONAL: Valkey or Redis hostname. The Compose stack defaults this to its
# bundled cache service. Leave empty for standalone Hearth without a cache.
CACHE_HOST=

# OPTIONAL: Valkey or Redis TCP port.
# DEFAULT: 6379.
CACHE_PORT=

# OPTIONAL: Valkey or Redis ACL username and password.
CACHE_USERNAME=
CACHE_PASSWORD=

# OPTIONAL: Redis database index from 0 through 15.
# DEFAULT: 0.
CACHE_DATABASE=

# OPTIONAL: Enable TLS for the cache connection.
# DEFAULT: false.
CACHE_TLS=

# Hearth Environment

# REQUIRED: Public URL of the Hearth Panel
KILN_URL=https://kiln.site

# OPTIONAL: environment mode - Options: prod | dev
# DEFAULT: prod
KILN_ENVIRONMENT=prod

# OPTIONAL (build time): source revision displayed in the panel footer. Common
# DEFAULT: detects common env vars - GITHUB_SHA, COMMIT_SHA, and SOURCE_COMMIT.
KILN_BUILD_SHA=

# OPTIONAL: Allow users to sign up for an account
# DEFAULT: false
KILN_ENABLE_SIGNUPS=false

# OPTIONAL Creates initial super user account (does nothing if users already exist)
# DEFAULT: none - Use the browser-based first-user flow.
KILN_SUPER_USER_EMAIL=
KILN_SUPER_USER_PASSWORD=

# Relay Initialization

# OPTIONAL: Relay URL used to initialize the first Relay. Must be an HTTP(S)
# origin without credentials, a path, query, or fragment.
# DEFAULT: none
KILN_RELAY_URL=

# OPTIONAL: Name for the initialized Relay
# DEFAULT: Primary Relay
KILN_RELAY_NAME=Primary Relay

# REQUIRED with KILN_RELAY_URL: Authentication key matching the Relay
# Generate with: openssl rand -base64 48
KILN_RELAY_KEY=

# OPTIONAL: Relay-side Brick catalog
# DEFAULT: official kiln-site/bricks catalog
KILN_BRICKS_CATALOG_URL=https://raw.githubusercontent.com/kiln-site/bricks/main/catalog.yml

# Better Auth

# REQUIRED: Versioned secrets for authentication and Relay credentials
# Generate with: openssl rand -base64 48
# Docs: https://better-auth.com/docs/reference/options#secrets
BETTER_AUTH_SECRETS=1:

# OPTIONAL: Additional trusted browser origins, comma-separated
# DEFAULT: KILN_URL and Kiln's local development origins
BETTER_AUTH_TRUSTED_ORIGINS=

# Resend

# OPTIONAL: Resend credentials for authentication and invitation emails
# DEFAULT: none - Authentication codes and invitation links are written to logs
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# mclogs

# OPTIONAL: mclo.gs upload API
# DEFAULT: https://api.mclo.gs/1/log
MCLOGS_API_URL=

# Sentry

# OPTIONAL: Enables server-side Sentry delivery. When empty, Sentry is disabled.
SENTRY_DSN=

# OPTIONAL: Enables browser Sentry delivery. This value is public and is baked
# into the client at image build time; pass it as a Docker build argument or CI
# variable. When empty, browser Sentry is disabled.
VITE_SENTRY_DSN=

# OPTIONAL: Uploads production source maps during builds. Keep this secret in CI.
SENTRY_AUTH_TOKEN=

# OPTIONAL: Fraction of server and browser transactions captured (0–1).
# DEFAULT: 0.1 in production, 1 in development
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1

# OPTIONAL: Fraction of non-error browser sessions captured by Session Replay.
# DEFAULT: 0.1. Error sessions are always captured.
VITE_SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1

# OPTIONAL: Enables the authenticated server verification route. Use only
# during setup and remove the value after confirming delivery.
KILN_SENTRY_VERIFICATION_TOKEN=

# OPTIONAL (development only): Exposes window.__kilnVerifySentry for testing
# browser event delivery. Has no effect in production builds.
# DEFAULT: false
VITE_SENTRY_VERIFICATION_ENABLED=false
